local function runSpray(mode)
    local char = _LocalPlayer20.Character
    local brick = _replicated:FindFirstChild('Brick')
    local tool = _LocalPlayer20.Backpack:FindFirstChild('Paint') or char:FindFirstChild('Paint')
    if tool and char:FindFirstChild("HumanoidRootPart") then
        local remote = tool:WaitForChild('Script'):WaitForChild('Event')
        
        if mode == "revert" then
            remote:FireServer(brick, Enum.NormalId.Top, char.HumanoidRootPart.Position, "both \u{1F91D}", Color3.fromRGB(192, 192, 192), "plastic","")
            task.wait(0.1)
            remote:FireServer(brick, Enum.NormalId.Top, char.HumanoidRootPart.Position, "both \u{1F91D}", Color3.fromRGB(173, 172, 175), "spray", "")
            task.wait(0.1)
            remote:FireServer(brick, Enum.NormalId.Bottom, char.HumanoidRootPart.Position, "both \u{1F91D}", Color3.fromRGB(173, 172, 175), "spray", "")
            task.wait(0.1)
            remote:FireServer(brick, Enum.NormalId.Left, char.HumanoidRootPart.Position, "both \u{1F91D}", Color3.fromRGB(173, 172, 175), "spray", "")
            task.wait(0.1)
            remote:FireServer(brick, Enum.NormalId.Right, char.HumanoidRootPart.Position, "both \u{1F91D}", Color3.fromRGB(173, 172, 175), "spray", "")
            task.wait(0.1)
            remote:FireServer(brick, Enum.NormalId.Back, char.HumanoidRootPart.Position, "both \u{1F91D}", Color3.fromRGB(173, 172, 175), "spray", "")
            task.wait(0.1)
            remote:FireServer(brick, Enum.NormalId.Front, char.HumanoidRootPart.Position, "both \u{1F91D}", Color3.fromRGB(173, 172, 175), "spray", "")
            if not brick.Anchored then
                task.wait(0.1)
                remote:FireServer(brick, Enum.NormalId.Top, char.HumanoidRootPart.Position, "material", Color3.fromRGB(173, 172, 175), "anchor", "")
            end
            if not brick.CanCollide then
                task.wait(0.1)
                remote:FireServer(brick, Enum.NormalId.Top, char.HumanoidRootPart.Position, "material", Color3.fromRGB(173, 172, 175), "collide", "")
            end
            return
        end

        if mode == "rainbow" then 
            local rainbowCol = Color3.fromHSV(tick() * _rainbowSpeed % 1, 1, 1) 
            for targetPart, hitPos in pairs(_paintTargets) do
                if targetPart and targetPart.Parent then
                    remote:FireServer(targetPart, "Front", hitPos, 'both \u{1f91d}', rainbowCol, "spray", " ")
                    task.wait(0.04)
                else
                    _paintTargets[targetPart] = nil 
                end
            end
            return
        end

        local blockCol = parseColor(ColorInput.Text, Color3.fromRGB(163, 162, 165))
        local sprayCol = parseColor(SprayColorInput.Text, Color3.fromRGB(255, 255, 255))
        local sprayHex = rgbToHex(sprayCol)
        local textTable = string.split(InputBox.Text, ",")
        local activeSides = {}
        for _, s in ipairs(sidesOrdered) do if _sideStates[s] then table.insert(activeSides, s) end end
        
        if brick then
            if mode == "anchor" or mode == "toxic" or mode == "plastic" or mode == "smooth" then
                remote:FireServer(brick, "Front", brick.Position, 'both \u{1f91d}', blockCol, mode, " ")
            else
                for i, side in ipairs(activeSides) do
                    local txt = textTable[i] or textTable[1] or " "
                    txt = txt:gsub("^%s*(.-)%s*$", "%1")
                    local taggedText = '<font color="'.. sprayHex ..'">' .. txt .. '</font>'
                    remote:FireServer(brick, side, brick.Position, 'both \u{1f91d}', blockCol, "spray", taggedText)
                    task.wait(_pingDelay)
                end
            end
        end
    end
end

_runService.Heartbeat:Connect(function()
    local char = _LocalPlayer20.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return end
    local hrp = char.HumanoidRootPart
    local hum = char:FindFirstChild("Humanoid")
    local myPos = hrp.Position
    local brick = _replicated:FindFirstChild("Brick")

    -- 1. INDEPENDENT COMMAND GRIEFING
    if _CMD_GriefActive then
        local delTool = char:FindFirstChild("Delete") or _LocalPlayer20.Backpack:FindFirstChild("Delete")
        if delTool then
            local event = delTool:FindFirstChild("Script") and delTool.Script:FindFirstChild("Event")
            if event then
                if _GriefMode == "G1" then
                    if brick then event:FireServer(brick, myPos) end 
                    if (tick() - _CMD_LastScan) >= _scanInterval then
                        _CMD_LastScan = tick()
                        for _, obj in pairs(_workspace:GetDescendants()) do
                            if obj:IsA("BasePart") and obj.Name ~= "Terrain" and not obj:IsDescendantOf(char) and obj ~= brick then
                                event:FireServer(obj, myPos) -- INF RANGE
                            end
                        end
                    end
                elseif _GriefMode == "G2" then
                    local oldPos = hrp.CFrame
                    local targets = {}
                    for _, obj in pairs(_workspace:GetDescendants()) do
                        if obj:IsA("BasePart") and obj.Name == "Brick" and not obj:IsDescendantOf(char) then table.insert(targets, obj) end
                    end
                    for i = 1, #targets do
                        if not _CMD_GriefActive then break end
                        local target = targets[i]
                        if target and target.Parent then
                            hrp.CFrame = target.CFrame
                            task.wait(_GriefSpeed)
                            event:FireServer(target, target.Position)
                        end
                    end
                    _CMD_GriefActive = false
                    hrp.CFrame = oldPos
                end
            end
        end
    end

    -- 2. GUI FEATURES
    if not _buildingDisabled then
        local delTool = char:FindFirstChild("Delete") or _LocalPlayer20.Backpack:FindFirstChild("Delete")
        if delTool and not _CMD_GriefActive then
            local event = delTool:FindFirstChild("Script") and delTool.Script:FindFirstChild("Event")
            if event then
                if _breakBkitEnabled and brick then event:FireServer(brick, myPos) end
                
                if _deleteAuraEnabled and (tick() - _lastAuraScan) >= _scanInterval then
                    _lastAuraScan = tick()
                    local range = tonumber(RangeInput.Text) or 100
                    for _, obj in pairs(_workspace:GetDescendants()) do
                        if obj:IsA("BasePart") and obj.Name ~= "Terrain" and not obj:IsDescendantOf(char) and obj ~= brick then
                            if (obj.Position - myPos).Magnitude <= range then 
                                event:FireServer(obj, myPos)
                            end
                        end
                    end
                end
            end
        end
        
        if _unanchorAuraEnabled then
            local bricksFolder = _workspace:FindFirstChild("Bricks")
            local tool = char:FindFirstChild('Paint') or _LocalPlayer20.Backpack:FindFirstChild('Paint')
            if bricksFolder and tool then
                local remote = tool:WaitForChild('Script'):WaitForChild('Event')
                local oldCFrame = hrp.CFrame
                local range = tonumber(RangeInput.Text) or 100
                for _, b in pairs(bricksFolder:GetChildren()) do
                    if b:IsA("BasePart") and (b.Position - myPos).Magnitude <= range then
                        hrp.CFrame = b.CFrame
                        task.wait(0.04)
                        remote:FireServer(b, "Front", b.Position, 'both \u{1f91d}', Color3.new(1,1,1), "anchor", " ")
                        hrp.CFrame = oldCFrame
                        task.wait(0.04)
                    end
                end
            end
        end
        
        if _rainbowEnabled then runSpray("rainbow") end
    end

    -- Misc
    if _antiJailEnabled then
        local jail = char:FindFirstChild("Jail")
        if jail then jail:Destroy() end
    end

    if _autoRecoveryEnabled and hum and hum.Health <= 0 then
        for _, tool in pairs(char:GetChildren()) do
            if tool:IsA("Tool") then tool.Parent = _workspace end
        end
        for _, tool in pairs(_LocalPlayer20.Backpack:GetChildren()) do
            if tool:IsA("Tool") then tool.Parent = _workspace end
        end
    end

    if _autoSayEnabled and AutoSayInput.Text ~= "" then
        local now = tick()
        local d = tonumber(SayDelayInput.Text) or 5
        if (now - _lastSay) >= d then
            _lastSay = now
            if _textChatService.ChatVersion == Enum.ChatVersion.TextChatService then
                local channel = _textChatService.TextChannels:FindFirstChild("RBXGeneral")
                if channel then channel:SendAsync(AutoSayInput.Text) end
            else
                local sayEvent = _replicated:FindFirstChild("DefaultChatSystemChatEvents") and _replicated.DefaultChatSystemChatEvents:FindFirstChild("SayMessageRequest")
                if sayEvent then sayEvent:FireServer(AutoSayInput.Text, "All") end
            end
        end
    end

    if hum and hum.Health > 0 and not char:FindFirstChild("Hielo") then _lastSafePos = hrp.CFrame end
    if _antiFreezeEnabled and char:FindFirstChild("Hielo") and hum and hum.Health > 0 then
        _shouldTeleportBack = true
        hum.Health = 0
    end
end)

