function Aura:Destroy()
    if chatConnection then chatConnection:Disconnect() end
    if noclipConnection then noclipConnection:Disconnect() end
    if bsGui then bsGui:Destroy() end
    for _, loop in pairs(activeLoops) do if typeof(loop) == "RBXScriptConnection" then loop:Disconnect() elseif typeof(loop) == "thread" then task.cancel(loop) end end
    if self.Gui then self.Gui:Destroy() end
    print("Aura Framework: Session Terminated.")
end

