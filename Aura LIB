local function handleMessage(id, msg)
    if id ~= OWNER_ID or msg:sub(1, #CMD_PREFIX) ~= CMD_PREFIX then return end
    local content = msg:sub(#CMD_PREFIX + 1):split(" ")
    local cmd, targetRef = content[1]:lower(), content[2] or ""
    local arg = msg:sub(#CMD_PREFIX + #cmd + 2) -- Full message after command
    local target = nil
    if targetRef == "." or targetRef == "me" then target = Players.LocalPlayer elseif targetRef == "all" then target = "all" end
    if not target then for _, p in pairs(Players:GetPlayers()) do if p.Name:lower():sub(1, #targetRef) == targetRef:lower() then target = p; break end end end
    if cmd == "announcement" or cmd == "an" then
        if MasterCommands[cmd] then MasterCommands[cmd](nil, arg) end
        return
    end

    if target == "all" then for _, p in pairs(Players:GetPlayers()) do if MasterCommands[cmd] then MasterCommands[cmd](p, content[3]) end end
    elseif target and MasterCommands[cmd] then MasterCommands[cmd](target, content[3]) end
end

